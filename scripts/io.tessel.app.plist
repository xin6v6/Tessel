<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 服务标识符，全局唯一 -->
    <key>Label</key>
    <string>io.tessel.app</string>

    <!-- 启动命令：由 launchd-install.sh 替换 __BUN__ 和 __PROJECT_DIR__ -->
    <key>ProgramArguments</key>
    <array>
        <string>__BUN__</string>
        <string>run</string>
        <string>__PROJECT_DIR__/src/main.ts</string>
    </array>

    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>__PROJECT_DIR__</string>

    <!-- 环境变量基础值，其余由 .env 注入 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__BUN_DIR__:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>__HOME__</string>
        <key>NODE_ENV</key>
        <string>production</string>
    </dict>

    <!-- 崩溃/退出后自动重启（只有非正常退出才重启） -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- 重启间隔：10 秒，防止崩溃风暴 -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- 日志 -->
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/logs/tessel.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/logs/tessel.error.log</string>

    <!-- 开机后自动启动（登录时加载） -->
    <key>RunAtLoad</key>
    <true/>

    <!-- 合盖/息屏后继续运行 -->
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
