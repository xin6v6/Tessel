{
  "servers": {
    "jira": {
      "transport": "stdio",
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "${JIRA_URL}",
        "JIRA_USERNAME": "${JIRA_USERNAME}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    },
    "bitbucket": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "env": {
        "ATLASSIAN_SITE_NAME": "${BITBUCKET_SITE_NAME}",
        "ATLASSIAN_USER_EMAIL": "${BITBUCKET_USER_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${BITBUCKET_API_TOKEN}"
      }
    }
  }
}
