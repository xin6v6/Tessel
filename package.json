{
  "name": "synod",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "daemon": "bash scripts/start.sh --daemon",
    "stop": "bash scripts/start.sh --stop",
    "status": "bash scripts/start.sh --status",
    "logs": "tail -f data/logs/$(date +%Y-%m-%d).log | jq -r '[.timestamp, (.level | ascii_upcase | .[0:5]), .logger, (.sessionId // \"\"), .message] | @tsv'",
    "logs:raw": "tail -f data/logs/$(date +%Y-%m-%d).log",
    "logs:errors": "tail -f data/logs/$(date +%Y-%m-%d).error.log | jq -r '[.timestamp, .level, .logger, .message] | @tsv'",
    "logs:debug": "LOG_LEVEL=debug bun run src/main.ts",
    "traces": "tail -n 20 data/traces.jsonl | jq '{ts,sessionId,userId,source,route,tokens,timing:(.timing.totalMs|tostring)+\"ms\"}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "ui": "bun --hot src/ui/server.ts",
    "contacts": "bun run scripts/contacts.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "@slack/bolt": "^4.7.2",
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "langchain": "^1.4.2",
    "lucide-react": "^1.16.0",
    "openai": "^6.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  }
}
