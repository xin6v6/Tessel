# ================================================================
# Tessel — 环境配置模板
# 复制为 .env 并填入真实密钥
# ================================================================

# ----------------------------------------------------------------
# LLM Provider 选择
# 可选值: anthropic | openai | openai-compatible
# ----------------------------------------------------------------
LLM_PROVIDER=openai-compatible

# ----------------------------------------------------------------
# OpenAI-Compatible（MiniMax、DeepSeek、Moonshot 等）
# ----------------------------------------------------------------
OPENAI_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7-highspeed

# ----------------------------------------------------------------
# Vision Agent（识图节点）
# ----------------------------------------------------------------
# 留空则复用主模型（LLM_BASE_URL / OPENAI_API_KEY / LLM_MODEL）。
# 如需独立视觉模型（如 qwen-vl-plus、gpt-4o）单独配置：
# VISION_MODEL=MiniMax-M3  # MiniMax M3 支持视觉；也可用 gpt-4o
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_API_KEY=

# ----------------------------------------------------------------
# Image Generation Agent（文生图节点）
# ----------------------------------------------------------------
# 留空则使用 MiniMax image-01（默认）。
# IMAGEGEN_MODEL    模型名，默认 image-01
# IMAGEGEN_BASE_URL API 地址，默认 https://api.minimaxi.com/v1
# IMAGEGEN_API_KEY  API Key，默认复用 OPENAI_API_KEY

# ----------------------------------------------------------------
# Router（本地 ONNX 判别模型，零 LLM 开销）
# ----------------------------------------------------------------
# 先训练模型：cd scripts/train-router && python3 train.py
# 再启动服务：python3 serve.py
# 服务未启动时 router 自动 fallback 到 "chat"，不会崩。
CLASSIFIER_URL=http://classifier:9876  # 生产(Docker内网); 本地开发改为 http://127.0.0.1:9876
CLASSIFIER_TIMEOUT=200                 # 请求超时 ms；超时即 fallback chat
CLASSIFIER_MIN_CONF=0.5                # 置信度阈值；低于此值视为不确定 → fallback chat

# ----------------------------------------------------------------
# Anthropic（备用）
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------
# 运行时
# ----------------------------------------------------------------
# 终端日志级别: silent | fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# 文件日志级别（写入 data/logs/）: 默认 debug（比终端更详细）
# LOG_FILE_LEVEL=debug

# 终端输出格式: 留空为彩色文本，设为 json 则输出 JSON（生产环境推荐）
# LOG_FORMAT=json

# ----------------------------------------------------------------
# Integrations
# ----------------------------------------------------------------

# Slack Bot Token（xoxb- 开头）
# 获取地址: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=

# Slack App Token（xapp- 开头，Socket Mode 必须）
# 获取地址: https://api.slack.com/apps → Basic Information → App-Level Tokens
# 需要勾选 connections:write scope
SLACK_APP_TOKEN=

# ----------------------------------------------------------------
# Workflow Runner（多阶段任务调度，如 coding）
# ----------------------------------------------------------------

# coding workflow 的目标仓库由 CODING_REPOS 按【频道】决定（见下）。
# CODING_REPO_PATH 仅作为 recipe.cwdEnv 的占位，runner 不再用它回退 —— 没映射
# 的频道直接拒绝，不会跑到这个仓库。可留空。
CODING_REPO_PATH=

# 频道 → 目标仓库 映射（一频道一项目）。格式：channelId:repoPath，逗号分隔。
# 在某个 Slack 频道里 @bot 触发 coding workflow 时，按该频道选对应仓库。
# 例: CODING_REPOS=C0123ABC:/Users/me/proj-a,C0456DEF:/Users/me/proj-b
# 【没在这里映射的频道（含 DM）一律不能跑 workflow】——不回退默认，避免误改仓库。
CODING_REPOS=

# 允许触发 workflow 的用户白名单（逗号分隔的 userId，格式 <source>:<externalId>）。
# 例: slack:U094B755UQ3,cli:xin
CODING_ALLOWLIST=

# workflow 各 stage 底层用 Claude Agent SDK。后端切换（同一份代码）：
#   本地：留空（用已登录的 claude 凭证）或设 ANTHROPIC_API_KEY → 真 Claude
#   生产：设 ANTHROPIC_BASE_URL + ANTHROPIC_API_KEY → DeepSeek（自动映射 claude-* 模型名）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=

# workflow 运行统计 sqlite（默认 data/workflow-stats.sqlite，gitignored）
# WORKFLOW_STATS_DB=data/workflow-stats.sqlite

# ----------------------------------------------------------------
# 验收 agent（scripts/acceptance.ts —— 以你身份 DM bot 做端到端验收）
# ----------------------------------------------------------------

# 你本人的 Slack user token（xoxp- 开头）。用于以你的身份给 bot 发 DM。
# scope 需要：chat:write, im:write, im:history
SLACK_USER_TOKEN=

# bot 的 user id（如 U0B0JBBMJBS）。验收脚本据此在 DM 历史里识别 bot 的回复。
# 获取：用 SLACK_BOT_TOKEN 调 auth.test，看 user_id。
SLACK_BOT_USER_ID=
