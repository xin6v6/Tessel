# ================================================================
# Tessel — 环境配置模板
# 复制为 .env 并填入真实密钥
# ================================================================

# ----------------------------------------------------------------
# LLM Provider 选择
# 可选值: anthropic | openai | openai-compatible
# ----------------------------------------------------------------
LLM_PROVIDER=openai-compatible

# ----------------------------------------------------------------
# OpenAI-Compatible（MiniMax、DeepSeek、Moonshot 等）
# ----------------------------------------------------------------
OPENAI_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7-highspeed

# ----------------------------------------------------------------
# Router（前置快速分类节点，在 supervisor 之前）
# ----------------------------------------------------------------
# Router 只把消息判成 chat/tool/workflow，是轻活。主模型（MiniMax M 系列）
# 全是推理模型、延迟抖动大（实测 1.2~6.5s），且关不掉思考 —— 不适合做 router。
# 要快就接一个独立 endpoint 并【关掉思考】。实测推荐 ↓
#
# 用法：去 platform.deepseek.com 拿一个 key，填下面几行即可（不用改代码）。
#   ROUTER_MODEL=deepseek-v4-flash             # 关思考后 ~0.9s、分类准；别用 deepseek-reasoner
#   ROUTER_BASE_URL=https://api.deepseek.com/v1
#   ROUTER_API_KEY=sk-...                      # DeepSeek 的 key
#
# 实测延迟（"给#general发消息" → tool）：
#   deepseek-v4-flash 开思考 ~1.9s（还会判飘）→ 关思考 ~0.9s ✅
#   主模型 MiniMax-M2.7 ~1.2~6.5s（关不掉思考、抖动大）
#
# 全部留空 = router 回退主模型（功能不变，只是不快）。
# ROUTER_BASE_URL / ROUTER_API_KEY 留空时分别复用 LLM_BASE_URL / OPENAI_API_KEY。
ROUTER_MODEL=
ROUTER_BASE_URL=
ROUTER_API_KEY=
# 关思考是提速关键：默认 off=注入 thinking:{type:"disabled"}（DeepSeek v4 必须靠它才快）。
# 换用一个需要思考才能分类的模型时，设 ROUTER_THINKING=on 关掉这个注入。
ROUTER_THINKING=off
ROUTER_MAX_TOKENS=256                # 关思考后用不满；回退推理模型时够容纳 <think>+结论
ROUTER_TIMEOUT_MS=8000               # 分类超时即回退 chat，不拖累主链路

# ----------------------------------------------------------------
# Anthropic（备用）
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------
# 运行时
# ----------------------------------------------------------------
# 终端日志级别: silent | fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# 文件日志级别（写入 data/logs/）: 默认 debug（比终端更详细）
# LOG_FILE_LEVEL=debug

# 终端输出格式: 留空为彩色文本，设为 json 则输出 JSON（生产环境推荐）
# LOG_FORMAT=json

# ----------------------------------------------------------------
# Integrations
# ----------------------------------------------------------------

# Slack Bot Token（xoxb- 开头）
# 获取地址: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=

# Slack App Token（xapp- 开头，Socket Mode 必须）
# 获取地址: https://api.slack.com/apps → Basic Information → App-Level Tokens
# 需要勾选 connections:write scope
SLACK_APP_TOKEN=

# ----------------------------------------------------------------
# Workflow Runner（多阶段任务调度，如 coding）
# ----------------------------------------------------------------

# coding workflow 干活的目标仓库（绝对路径）。改 bug / 加功能等都在这里执行。
CODING_REPO_PATH=

# 允许触发 workflow 的用户白名单（逗号分隔的 userId，格式 <source>:<externalId>）。
# 例: slack:U094B755UQ3,cli:xin
CODING_ALLOWLIST=

# workflow 各 stage 底层用 Claude Agent SDK。后端切换（同一份代码）：
#   本地：留空（用已登录的 claude 凭证）或设 ANTHROPIC_API_KEY → 真 Claude
#   生产：设 ANTHROPIC_BASE_URL + ANTHROPIC_API_KEY → DeepSeek（自动映射 claude-* 模型名）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_API_KEY=

# workflow 运行统计 sqlite（默认 data/workflow-stats.sqlite，gitignored）
# WORKFLOW_STATS_DB=data/workflow-stats.sqlite

# ----------------------------------------------------------------
# 验收 agent（scripts/acceptance.ts —— 以你身份 DM bot 做端到端验收）
# ----------------------------------------------------------------

# 你本人的 Slack user token（xoxp- 开头）。用于以你的身份给 bot 发 DM。
# scope 需要：chat:write, im:write, im:history
SLACK_USER_TOKEN=

# bot 的 user id（如 U0B0JBBMJBS）。验收脚本据此在 DM 历史里识别 bot 的回复。
# 获取：用 SLACK_BOT_TOKEN 调 auth.test，看 user_id。
SLACK_BOT_USER_ID=
